rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Imágenes de productos: lectura pública.
    // Las imágenes se suben a Cloudinary via backend firmado — Firebase Storage
    // no recibe escrituras directas desde el cliente.
    match /products/{allPaths=**} {
      allow read:  if true;
      allow write: if false;
    }
  }
}
