rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: usuario autenticado con role admin en Firestore ──
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Helper: validación de campos al escribir un producto ────
    // Previene que alguien (incluso un admin desde la consola)
    // guarde price negativo, stock negativo o nombre vacío.
    function validProductData() {
      let d = request.resource.data;
      return d.name is string
        && d.name.size() > 0
        && d.price is number
        && d.price > 0
        && d.stock is number
        && d.stock >= 0;
    }

    // ── products ─────────────────────────────────────────────────
    // Lectura pública (catálogo visible para todos).
    // Escritura solo para admins con validación de campos.
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && validProductData();
      allow update: if isAdmin() && validProductData();
      allow delete: if isAdmin();
    }

    // ── users ─────────────────────────────────────────────────────
    // Cada usuario solo puede leer su propio documento.
    // Escritura completamente bloqueada desde el cliente:
    // los roles se asignan exclusivamente desde el Admin SDK / consola.
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── orders ────────────────────────────────────────────────────
    // Creadas y actualizadas SOLO por el Admin SDK (Firebase Functions).
    // El Admin SDK bypasea estas reglas, por eso write: false es seguro.
    // Los admins pueden leer desde el panel para gestionar pedidos.
    // Ningún cliente no-admin puede leer ni modificar órdenes.
    match /orders/{orderId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── payments ──────────────────────────────────────────────────
    // Registro de auditoría. Solo escribe el webhook via Admin SDK.
    // Solo un admin puede leer desde el panel.
    match /payments/{paymentId} {
      allow read:  if isAdmin();
      allow write: if false;
    }
  }
}
